{
  "name": "chatgpt-exporter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "start": "node server/index.js",
    "mcp": "node mcp/index.js",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node mcp/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run --coverage && playwright test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.3",
    "chatgpt-share-parser": "^0.1.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "http-terminator": "^3.2.0",
    "lru-cache": "^11.5.2",
    "lucide-react": "^1.24.0",
    "p-queue": "^9.3.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
